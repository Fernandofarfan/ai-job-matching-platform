# =================================================================
# 🤖 EMPLEOIA - CONFIGURACIÓN DE VARIABLES DE ENTORNO
# =================================================================
# Instrucciones:
# 1. Copiá este archivo como '.env' en la raíz del proyecto.
# 2. Completá los valores con tus credenciales.
# 3. NUNCA subas el archivo '.env' a un repositorio público.
# =================================================================

# -----------------------------------------------------------------
# 🧠 CORE & INTELIGENCIA ARTIFICIAL
# -----------------------------------------------------------------
# Obtené tu API key gratis en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_api_key_aqui

# -----------------------------------------------------------------
# 🗄️ BASE DE DATOS (MySQL)
# -----------------------------------------------------------------
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=tu_password_mysql
DB_NAME=job_tracker
DB_POOL_SIZE=5
DB_POOL_NAME=job_pool_v2

# -----------------------------------------------------------------
# ⚡ CELERY + REDIS (Tareas Asíncronas)
# -----------------------------------------------------------------
# Para desarrollo local: instalar Redis o usar Docker
# Windows: usar WSL2 o Docker Desktop con redis:7-alpine
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------
# 🔍 SCRAPER: INDEED (Vía Google Login)
# -----------------------------------------------------------------
INDEED_EMAIL=tu_email_google@gmail.com
INDEED_PASSWORD=tu_password_google

# NOTA: Si tenés 2FA (verificación en 2 pasos) activa en Google:
# - Deberás aprobar el login en tu celular al iniciar el scraper.
# - O podés usar una "Contraseña de Aplicación" de Google.

# -----------------------------------------------------------------
# 🔍 SCRAPER: LINKEDIN
# -----------------------------------------------------------------
# Opción A: Email y Contraseña (Recomendado para inicio automático)
LINKEDIN_EMAIL=tu_email@ejemplo.com
LINKEDIN_PASSWORD=tu_password

# Opción B: Cookie 'li_at' (Más estable contra bloqueos)
# Obtenela de: Herramientas desarrollador -> Application -> Cookies
LINKEDIN_TOKEN=tu_linkedin_cookie_token

# -----------------------------------------------------------------
# 🔍 SCRAPERS: BUMERAN & COMPUTRABAJO (Opcional)
# -----------------------------------------------------------------
BUMERAN_EMAIL=tu_email@ejemplo.com
BUMERAN_PASSWORD=tu_password

COMPUTRABAJO_EMAIL=tu_email@ejemplo.com
COMPUTRABAJO_PASSWORD=tu_password

# -----------------------------------------------------------------
# 📧 NOTIFICACIONES POR EMAIL (SMTP)
# -----------------------------------------------------------------
# Para Gmail: usá una Contraseña de Aplicación (no tu contraseña normal)
# Crear en: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_app_password_de_google
# Email donde recibirás las notificaciones
NOTIFICATION_EMAIL=tu_email@gmail.com

# -----------------------------------------------------------------
# 🌸 FLOWER DASHBOARD (Monitor de Celery)
# -----------------------------------------------------------------
FLOWER_USER=admin
FLOWER_PASSWORD=admin123

# -----------------------------------------------------------------
# ☁️ DESPLIEGUE EN LA NUBE (Solo si usás Docker/Terraform)
# -----------------------------------------------------------------
# GCP Project ID (para Terraform)
# GCP_PROJECT_ID=mi-proyecto-gcp
